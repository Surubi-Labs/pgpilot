# ─── Local Postgres (docker/docker-compose.yml) ────────────
POSTGRES_USER=pgpilot
POSTGRES_PASSWORD=pgpilot
POSTGRES_DB=pgpilot
POSTGRES_PORT=5432

# Connection strings (derived)
DATABASE_URL=postgres://pgpilot:pgpilot@localhost:5432/pgpilot

# ─── Runtime ───────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

